#-----------------------------------------------------------------------------# 
# Cognibrew Cloud Airflow
#-----------------------------------------------------------------------------#
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Postgres
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

#-----------------------------------------------------------------------------# 
# Cognibrew Cloud Infrastructure
#-----------------------------------------------------------------------------#
INFRA_POSTGRES_USER=cognibrew
INFRA_POSTGRES_PASSWORD=cognibrew
INFRA_POSTGRES_DB=mlflowdb
INFRA_MLFLOW_WORKERS=2
INFRA_MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts/
INFRA_MLFLOW_S3_ENDPOINT_URL=http://rustfs:9000

#-----------------------------------------------------------------------------# 
# Cognibrew Cloud Edge Gateway
#-----------------------------------------------------------------------------#
CCEG_LOG_LEVEL=INFO

# Application
CCEG_ENVIRONMENT=production
CCEG_API_PREFIX_STR=/api/v1
CCEG_PROJECT_NAME=CogniBrew Edge Gateway

# S3 / RustFS
CCEG_S3_ENDPOINT_URL=http://rustfs:9000
CCEG_S3_ACCESS_KEY=rustfsadmin
CCEG_S3_SECRET_KEY=rustfsadmin
CCEG_S3_BUCKET_NAME=cognibrew-raw

#-----------------------------------------------------------------------------# 
# Cognibrew Cloud Edge Sync
#-----------------------------------------------------------------------------#
CCES_LOG_LEVEL=INFO

# Application
CCES_ENVIRONMENT=local
CCES_API_PREFIX_STR=/api/v1
CCES_PROJECT_NAME=CogniBrew Edge Sync

# Upstream Services
CCES_VECTOR_OPERATION_URL=http://vector-operation:8000

# Sync pagination
CCES_SYNC_PAGE_SIZE=50

#-----------------------------------------------------------------------------# 
# Cognibrew Cloud Vector Operation
#-----------------------------------------------------------------------------# 
CCVO_LOG_LEVEL=INFO

# Application
CCVO_ENVIRONMENT=production
CCVO_API_PREFIX_STR=/api/v1
CCVO_PROJECT_NAME=CogniBrew Vector Operation

# Qdrant
CCVO_QDRANT_HOST=qdrant
CCVO_QDRANT_PORT=6334
CCVO_QDRANT_COLLECTION=face_embeddings
CCVO_EMBEDDING_DIM=512

# MLflow
CCVO_MLFLOW_TRACKING_URI=http://mlflow:5000
CCVO_MLFLOW_EXPERIMENT_NAME=vector-evolution

# Gallery / Baseline Update
CCVO_MAX_VECTORS_PER_USER=10
CCVO_UPPER_SIMILARITY_THRESHOLD=0.92
CCVO_LOWER_SIMILARITY_THRESHOLD=0.75
CCVO_EMA_ALPHA=0.1

# Per-Device Threshold Calibration
CCVO_MIN_CALIBRATION_SAMPLES=10
CCVO_FALLBACK_SIMILARITY_THRESHOLD=0.5

#-----------------------------------------------------------------------------# 
# Cognibrew Cloud Inference Server
#-----------------------------------------------------------------------------# 
CCIS_LOG_LEVEL=INFO

# Model
CCIS_MODEL_FRAMEWORK=insightface
CCIS_MODEL_NAME=buffalo_sc